# ──────────────────────────────────────────────────────────────────────
# backend/.env ŞABLONU
#
# Kullanım:
#   1) Bu dosyayı backend/.env olarak kopyala
#   2) Aşağıdaki değerleri kendi ortamına göre doldur
#   3) backend/.env ASLA commit edilmez (.gitignore'da kilitli)
#
# Secret üretimi:
#   FERNET_KEY için:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ──────────────────────────────────────────────────────────────────────

# n8n entegrasyonu için API anahtarı (kullanılmıyorsa boş bırakılabilir)
N8N_API_KEY=

# PostgreSQL bağlantı URL'si
DATABASE_URL=

# DB'de api_anahtari kolonunu Fernet ile şifrelemek için master key.
# Boşsa eski kayıtlar düz metin okunur (geriye dönük uyumluluk).
# Üretimde MUTLAKA doldurulmalı; key kaybedilirse şifrelenmiş kayıtlar
# geri alınamaz — yedeğini güvenli yerde sakla.
FERNET_KEY=
