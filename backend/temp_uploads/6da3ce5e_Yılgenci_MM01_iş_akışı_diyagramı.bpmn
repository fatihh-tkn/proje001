    <bpmn:textAnnotation id="TextAnnotation_00nmyex">
      <bpmn:text>"02" girilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0jnbhyl">
      <bpmn:text>Üretim versiyonu varsa tik dolu gelir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_19qk5op">
      <bpmn:text>Mamul, yarı mamul yada sas malzemesi girilir</bpmn:text>
    </bpmn:textAnnotation>
