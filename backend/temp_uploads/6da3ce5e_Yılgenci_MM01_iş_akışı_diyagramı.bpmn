    <bpmn:textAnnotation id="TextAnnotation_09zctpw">
      <bpmn:text>"B" girilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1cl84kn">
      <bpmn:text>"G" girilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0naqy9v">
      <bpmn:text>"1" girilir</bpmn:text>
