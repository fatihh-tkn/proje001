    <bpmn:textAnnotation id="TextAnnotation_1lc68zz">
      <bpmn:text>"NORM" yazılır</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:group id="Group_0uo7syv" categoryValueRef="CategoryValue_1u7a021" />
    <bpmn:textAnnotation id="TextAnnotation_060ey5i">
      <bpmn:text>"02" (Münferit ihtiyaç) seçilir.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1kqs30c">
      <bpmn:text>"1030" yazılır.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0jr02fc">
      <bpmn:text>Tik atılır</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:group id="Group_1e4sw22" categoryValueRef="CategoryValue_1vp1gsy" />
    <bpmn:textAnnotation id="TextAnnotation_14tpu7d">
      <bpmn:text>"130" girilir.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_16rpc0b">
      <bpmn:text>"10008" girilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1qzsslf">
      <bpmn:text>Tik atılır</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:group id="Group_0ozwhfc" categoryValueRef="CategoryValue_1kwr195" />
    <bpmn:textAnnotation id="TextAnnotation_1t5kl6c">
      <bpmn:text>hangi firma için kullanılacak ise o girilmeli.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_19nnnno">
      <bpmn:text>"YG" girilir.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1kom953">
      <bpmn:text>"PD" girilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:group id="Group_1uxl3x7" categoryValueRef="CategoryValue_12tjw6m" />
    <bpmn:group id="Group_15poir6" categoryValueRef="CategoryValue_1mv21kk" />
    <bpmn:group id="Group_1h685pu" categoryValueRef="CategoryValue_0qfk5d5" />
    <bpmn:textAnnotation id="TextAnnotation_1anybf2">
      <bpmn:text>Seçeneğe göre belirlenir.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1ifaz73">
      <bpmn:text>"URETIM" girilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0uamo83">
      <bpmn:text>"20" girilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1w88cd4">
      <bpmn:text>Seçtiğimiz depo yerine göre otomatik dolar.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1e1eej6">
      <bpmn:text>fason , dahili veya hem içerde hem fason seçeneklerinden biri seçilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:group id="Group_1eoyi1o" categoryValueRef="CategoryValue_1g6m38l" />
    <bpmn:textAnnotation id="TextAnnotation_1dm7dze">
      <bpmn:text>"M" girilir</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:group id="Group_1fmwzpd" categoryValueRef="CategoryValue_0mqw9ak" />
    <bpmn:textAnnotation id="TextAnnotation_0w78igh">
      <bpmn:text>1 (Yalnızca münferit ihtiyaç) seçilir</bpmn:text>
    </bpmn:textAnnotation>
